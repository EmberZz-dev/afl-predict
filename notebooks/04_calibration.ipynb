   "source": [
    "## 1. Load Data & Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5j667gbu5c8",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-10T22:56:26.365628Z",
     "iopub.status.busy": "2026-03-10T22:56:26.365421Z",
     "iopub.status.idle": "2026-03-10T22:56:26.469454Z",
     "shell.execute_reply": "2026-03-10T22:56:26.468594Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train: 1447 | Test: 397\n",
      "Ensemble accuracy (uncalibrated): 65.7%\n"
     ]
    }
   ],
   "source": [
    "features = pd.read_csv(PROJECT_ROOT / \"data\" / \"processed\" / \"features.csv\", parse_dates=[\"date\"])\n",
    "df = features.dropna(subset=FEATURE_COLS + [\"home_win\", \"margin\"])\n",
    "\n",
    "train = df[df[\"season\"] < 2024]\n",
    "test = df[df[\"season\"] >= 2024]\n",
    "\n",
    "X_train = train[FEATURE_COLS]\n",
    "y_train = train[\"home_win\"].astype(int)\n",
    "X_test = test[FEATURE_COLS]\n",
    "y_test = test[\"home_win\"].astype(int)\n",
    "\n",
    "models_dir = PROJECT_ROOT / \"models\" / \"saved\"\n",
    "xgb_clf = joblib.load(models_dir / \"xgb_classifier.joblib\")\n",
    "lgbm_clf = joblib.load(models_dir / \"lgbm_classifier.joblib\")\n",
    "\n",
    "# Generate base predictions\n",
    "xgb_probs = xgb_clf.predict_proba(X_test)[:, 1]\n",
    "lgbm_probs = lgbm_clf.predict_proba(X_test)[:, 1]\n",
    "ensemble_probs = (xgb_probs + lgbm_probs) / 2\n",
    "ensemble_preds = (ensemble_probs >= 0.5).astype(int)\n",
    "\n",
    "print(f\"Train: {len(train)} | Test: {len(test)}\")\n",
    "print(f\"Ensemble accuracy (uncalibrated): {accuracy_score(y_test, ensemble_preds):.1%}\")"
   ]
  },
