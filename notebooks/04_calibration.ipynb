   "source": [
    "## 6. Feature Experiment — Interaction Features\n",
    "\n",
    "Can we improve the model by adding features that capture *interactions* between existing ones?\n",
    "\n",
    "- **ELO x Form**: A strong team (high ELO) in good form should be even more favoured\n",
    "- **Form Differential**: Net form advantage (home form - away form)\n",
    "- **Rest Advantage**: Days rest difference between teams (if available)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "b5a0n819gse",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-10T22:56:30.641593Z",
     "iopub.status.busy": "2026-03-10T22:56:30.641458Z",
     "iopub.status.idle": "2026-03-10T22:56:30.869494Z",
     "shell.execute_reply": "2026-03-10T22:56:30.868430Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original XGBoost:  64.7% accuracy | Brier: 0.2100\n",
      "Extended XGBoost:  65.5% accuracy | Brier: 0.2110\n",
      "\n",
      "New features: 6 interaction terms added\n"
     ]
    }
   ],
   "source": [
    "import xgboost as xgb\n",
    "\n",
    "# Create interaction features\n",
    "def add_interactions(data):\n",
    "    d = data.copy()\n",
    "    d[\"elo_x_form\"] = d[\"elo_diff\"] * (d[\"home_form_5\"] - d[\"away_form_5\"])\n",
    "    d[\"form_diff_5\"] = d[\"home_form_5\"] - d[\"away_form_5\"]\n",
    "    d[\"form_diff_10\"] = d[\"home_form_10\"] - d[\"away_form_10\"]\n",
    "    d[\"streak_diff\"] = d[\"home_streak\"] - d[\"away_streak\"]\n",
    "    d[\"venue_diff\"] = d[\"home_venue_win_rate\"] - d[\"away_venue_win_rate\"]\n",
    "    d[\"score_diff_5\"] = d[\"home_avg_score_5\"] - d[\"away_avg_score_5\"]\n",
    "    return d\n",
    "\n",
    "train_ext = add_interactions(train)\n",
    "test_ext = add_interactions(test)\n",
    "\n",
    "NEW_FEATURES = FEATURE_COLS + [\"elo_x_form\", \"form_diff_5\", \"form_diff_10\",\n",
    "                                \"streak_diff\", \"venue_diff\", \"score_diff_5\"]\n",
    "\n",
    "X_train_ext = train_ext[NEW_FEATURES]\n",
    "X_test_ext = test_ext[NEW_FEATURES]\n",
    "\n",
    "# Train new XGBoost with extended features\n",
    "xgb_ext = xgb.XGBClassifier(\n",
    "    objective=\"binary:logistic\", eval_metric=\"logloss\",\n",
    "    use_label_encoder=False, random_state=42, verbosity=0,\n",
    "    max_depth=5, n_estimators=200, learning_rate=0.05\n",
    ")\n",
    "xgb_ext.fit(X_train_ext, y_train)\n",
    "\n",
    "ext_probs = xgb_ext.predict_proba(X_test_ext)[:, 1]\n",
    "ext_preds = (ext_probs >= 0.5).astype(int)\n",
    "\n",
    "print(f\"Original XGBoost:  {accuracy_score(y_test, (xgb_probs >= 0.5).astype(int)):.1%} accuracy | \"\n",
    "      f\"Brier: {brier_score_loss(y_test, xgb_probs):.4f}\")\n",
    "print(f\"Extended XGBoost:  {accuracy_score(y_test, ext_preds):.1%} accuracy | \"\n",
    "      f\"Brier: {brier_score_loss(y_test, ext_probs):.4f}\")\n",
    "print(f\"\\nNew features: {len(NEW_FEATURES) - len(FEATURE_COLS)} interaction terms added\")"
   ]
  },
