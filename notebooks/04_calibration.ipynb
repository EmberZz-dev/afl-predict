    "]\n",
    "\n",
    "for name, probs, color in calibration_sets:\n",
    "    prob_true, prob_pred = calibration_curve(y_test, probs, n_bins=8, strategy=\"uniform\")\n",
    "    brier = brier_score_loss(y_test, probs)\n",
    "    axes[0].plot(prob_pred, prob_true, \"o-\", label=f\"{name} (Brier={brier:.4f})\",\n",
    "                 color=color, linewidth=2, markersize=7)\n",
    "\n",
    "axes[0].plot([0, 1], [0, 1], \"--\", color=\"gray\", label=\"Perfect\")\n",
    "axes[0].set_xlabel(\"Mean Predicted Probability\")\n",
    "axes[0].set_ylabel(\"Fraction of Positives\")\n",
    "axes[0].set_title(\"XGBoost: Calibration Comparison\")\n",
    "axes[0].legend(loc=\"upper left\", fontsize=9)\n",
    "axes[0].set_xlim(0.15, 0.9)\n",
    "axes[0].set_ylim(0.15, 0.9)\n",
    "axes[0].set_aspect(\"equal\")\n",
    "\n",
    "# Right: Ensemble calibration comparison\n",
