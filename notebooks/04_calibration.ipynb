    "# Tag each test game as correct/incorrect\n",
    "analysis = test.copy()\n",
    "analysis[\"predicted\"] = ensemble_preds\n",
    "analysis[\"prob\"] = ensemble_probs\n",
    "analysis[\"correct\"] = (analysis[\"predicted\"] == analysis[\"home_win\"].astype(int))\n",
    "analysis[\"confidence\"] = abs(analysis[\"prob\"] - 0.5)\n",
    "\n",
    "correct = analysis[analysis[\"correct\"]]\n",
    "wrong = analysis[~analysis[\"correct\"]]\n",
    "\n",
    "print(f\"Correct: {len(correct)} ({len(correct)/len(analysis):.1%})\")\n",
    "print(f\"Wrong:   {len(wrong)} ({len(wrong)/len(analysis):.1%})\")\n",
    "\n",
    "# Compare feature distributions: correct vs wrong predictions\n",
    "fig, axes = plt.subplots(2, 3, figsize=(16, 10))\n",
    "compare_features = [\"elo_diff\", \"home_form_5\", \"away_form_5\", \"home_streak\", \"h2h_home_wins_5\", \"confidence\"]\n",
    "\n",
    "for ax, feat in zip(axes.ravel(), compare_features):\n",
    "    ax.hist(correct[feat], bins=25, alpha=0.6, label=\"Correct\", color=\"#5cb85c\", density=True)\n",
    "    ax.hist(wrong[feat], bins=25, alpha=0.6, label=\"Wrong\", color=\"#d94a4a\", density=True)\n",
    "    ax.set_title(feat)\n",
    "    ax.legend()\n",
    "\n",
    "plt.suptitle(\"Feature Distributions: Correct vs Wrong Predictions\", fontsize=14, fontweight=\"bold\")\n",
    "plt.tight_layout()\n",
