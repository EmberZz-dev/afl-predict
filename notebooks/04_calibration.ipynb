   "source": [
    "## 7. Betting Simulation — Does Calibration Help?\n",
    "\n",
    "If we used these probabilities for betting, would calibrated predictions produce better expected value? This simulates flat-stake betting when our model disagrees with a \"market\" baseline (ELO)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "goq9ur9lzco",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-10T22:56:31.212749Z",
     "iopub.status.busy": "2026-03-10T22:56:31.212595Z",
     "iopub.status.idle": "2026-03-10T22:56:31.222561Z",
     "shell.execute_reply": "2026-03-10T22:56:31.221923Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "=== Betting Simulation (edge threshold = 5%) ===\n",
      "\n",
      "Uncalibrated Ensemble:\n",
      "  Bets placed: 230 / 397 games (58%)\n",
      "  Win rate:    53.9%\n",
      "  Total P&L:   +0.5 units\n",
      "  ROI:         +0.2%\n",
      "\n",
      "Calibrated Ensemble:\n",
      "  Bets placed: 221 / 397 games (56%)\n",
      "  Win rate:    35.3%\n",
      "  Total P&L:   -25.7 units\n",
      "  ROI:         -11.6%\n",
      "\n",
      "Note: This uses ELO as a proxy for market odds. Real bookmaker odds would be sharper.\n"
     ]
    }
   ],
   "source": [
    "def simulate_betting(model_probs, elo_probs, y_true, edge_threshold=0.05):\n",
    "    \"\"\"Simulate flat-stake betting when model probability differs from ELO by threshold.\"\"\"\n",
    "    results = []\n",
    "    for model_p, elo_p, actual in zip(model_probs, elo_probs, y_true):\n",
    "        edge = model_p - elo_p  # positive = model more bullish on home\n",
    "\n",
    "        if abs(edge) < edge_threshold:\n",
    "            continue  # No bet — not enough edge\n",
    "\n",
    "        # Convert ELO prob to implied odds (like a bookmaker)\n",
    "        if edge > 0:\n",
    "            # Bet on home win\n",
    "            implied_odds = 1 / elo_p\n",
    "            won = actual == 1\n",
    "        else:\n",
    "            # Bet on away win\n",
    "            implied_odds = 1 / (1 - elo_p)\n",
    "            won = actual == 0\n",
    "\n",
    "        profit = (implied_odds - 1) if won else -1  # flat $1 stake\n",
    "        results.append({\"edge\": edge, \"won\": won, \"profit\": profit, \"odds\": implied_odds})\n",
    "\n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "# Compare uncalibrated vs calibrated betting\n",
    "print(\"=== Betting Simulation (edge threshold = 5%) ===\\n\")\n",
    "\n",
    "for name, probs in [(\"Uncalibrated Ensemble\", ensemble_probs),\n",
    "                     (\"Calibrated Ensemble\", cal_ens_probs)]:\n",
    "    bets = simulate_betting(probs, test[\"elo_prob\"].values, y_test.values, edge_threshold=0.05)\n",
    "    if len(bets) == 0:\n",
    "        print(f\"{name}: No bets placed (edge never exceeded threshold)\")\n",
    "        continue\n",
    "    total_profit = bets[\"profit\"].sum()\n",
    "    roi = total_profit / len(bets) * 100\n",
    "    win_rate = bets[\"won\"].mean()\n",
    "\n",
    "    print(f\"{name}:\")\n",
    "    print(f\"  Bets placed: {len(bets)} / {len(y_test)} games ({len(bets)/len(y_test):.0%})\")\n",
    "    print(f\"  Win rate:    {win_rate:.1%}\")\n",
    "    print(f\"  Total P&L:   {total_profit:+.1f} units\")\n",
    "    print(f\"  ROI:         {roi:+.1f}%\")\n",
    "    print()\n",
    "\n",
    "print(\"Note: This uses ELO as a proxy for market odds. Real bookmaker odds would be sharper.\")"
   ]
  },
